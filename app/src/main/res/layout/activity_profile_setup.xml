<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_navy">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customize Your Profile"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
            android:textColor="@color/accent_gold"
            android:textStyle="bold" />

        <!-- Basic Info Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Basic Information"
            android:textStyle="bold"
            android:textColor="@color/bg_champagne"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Full Name"
            android:textColorHint="@color/bg_champagne"
            app:boxStrokeColor="@color/accent_gold"
            app:hintTextColor="@color/accent_gold"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Occupation"
            android:textColorHint="@color/bg_champagne"
            app:boxStrokeColor="@color/accent_gold"
            app:hintTextColor="@color/accent_gold"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etOccupation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 🧠 Personality & Behavior -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="🧠 Personality &amp; Behavior"
            android:textStyle="bold"
            android:textColor="@color/bg_champagne"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/bg_champagne"
            android:text="Communication Style"/>
        <RadioGroup
            android:id="@+id/rgCommunication"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <RadioButton android:id="@+id/rbDirect" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Direct" android:textColor="@color/white" android:buttonTint="@color/accent_gold"/>
            <RadioButton android:id="@+id/rbEmpathetic" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empathetic" android:textColor="@color/white" android:buttonTint="@color/accent_gold"/>
            <RadioButton android:id="@+id/rbAnalytical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Analytical" android:textColor="@color/white" android:buttonTint="@color/accent_gold"/>
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Decision Making (Logical, Emotional...)"
            android:textColorHint="@color/bg_champagne"
            app:boxStrokeColor="@color/accent_gold"
            app:hintTextColor="@color/accent_gold"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDecisionMaking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/bg_champagne"
            android:text="Energy Level (Introvert to Extrovert)"/>
        <com.google.android.material.slider.Slider
            android:id="@+id/sliderEnergy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="1"
            android:valueTo="10"
            android:stepSize="1"
            android:value="5"
            app:thumbColor="@color/accent_gold"
            app:trackColorActive="@color/accent_gold"
            app:trackColorInactive="@color/secondary_charcoal" />

        <!-- 🎯 Interests & Lifestyle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="🎯 Interests &amp; Lifestyle"
            android:textStyle="bold"
            android:textColor="@color/bg_champagne"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Favorite Genres (Music, Books...)"
            android:textColorHint="@color/bg_champagne"
            app:boxStrokeColor="@color/accent_gold"
            app:hintTextColor="@color/accent_gold"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etGenres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/bg_champagne"
            android:text="Preferred Activities (Select multiple)"/>
        <CheckBox android:id="@+id/cbOutdoors" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Outdoors" android:textColor="@color/white" android:buttonTint="@color/accent_gold"/>
        <CheckBox android:id="@+id/cbTech" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tech Tinkering" android:textColor="@color/white" android:buttonTint="@color/accent_gold"/>
        <CheckBox android:id="@+id/cbCreative" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Creative Arts" android:textColor="@color/white" android:buttonTint="@color/accent_gold"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Dietary Preferences"
            android:textColorHint="@color/bg_champagne"
            app:boxStrokeColor="@color/accent_gold"
            app:hintTextColor="@color/accent_gold"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDiet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 🚦 Red & Green Flags -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="🚦 Red &amp; Green Flags"
            android:textStyle="bold"
            android:textColor="@color/bg_champagne"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Green Flags (Comma separated)"
            android:textColorHint="@color/bg_champagne"
            app:boxStrokeColor="@color/accent_gold"
            app:hintTextColor="@color/accent_gold"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etGreenFlags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Red Flags (Comma separated)"
            android:textColorHint="@color/bg_champagne"
            app:boxStrokeColor="@color/accent_gold"
            app:hintTextColor="@color/accent_gold"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRedFlags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 🎨 Optional Enhancements -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="🎨 Optional Enhancements"
            android:textStyle="bold"
            android:textColor="@color/bg_champagne"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Favorite Quote"
            android:textColorHint="@color/bg_champagne"
            app:boxStrokeColor="@color/accent_gold"
            app:hintTextColor="@color/accent_gold"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:padding="16dp"
            android:text="Save &amp; Complete Profile"
            android:textColor="@color/primary_navy"
            android:backgroundTint="@color/accent_gold"
            app:cornerRadius="12dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="48dp" />

    </LinearLayout>
</ScrollView>
